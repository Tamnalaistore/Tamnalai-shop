<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TAMNALAI STORE</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>

body{
font-family:Poppins;
background:#0f0f12;
color:white;
margin:0;
}

header{
background:#14141a;
padding:15px;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
font-size:20px;
font-weight:600;
color:#d04bff;
}

.banner{
background:linear-gradient(45deg,#c03cff,#6b2cff);
padding:30px;
text-align:center;
border-radius:12px;
margin:15px;
}

.banner h2{
margin:0;
}

.container{
padding:15px;
}

.input-box{
margin-bottom:10px;
}

input{
width:100%;
padding:12px;
border-radius:8px;
border:none;
background:#1e1e26;
color:white;
}

.section-title{
margin-top:25px;
margin-bottom:10px;
font-size:18px;
}

.packages{
display:grid;
grid-template-columns:1fr 1fr;
gap:10px;
}

.package{
background:#1c1c24;
padding:15px;
border-radius:10px;
cursor:pointer;
border:2px solid transparent;
}

.package:hover{
border:2px solid #c03cff;
}

.price{
color:#d04bff;
font-weight:600;
}

button{
width:100%;
margin-top:20px;
padding:14px;
background:linear-gradient(45deg,#ff2bd6,#7c3cff);
border:none;
border-radius:10px;
font-size:16px;
color:white;
font-weight:600;
cursor:pointer;
}

footer{
text-align:center;
padding:20px;
opacity:0.7;
}

</style>
</head>

<body>

<header>
<div class="logo">TAMNALAI STORE</div>
</header>

<div class="banner">
<h2>Mobile Legends Top Up</h2>
<p>Fast • Safe • Instant Delivery</p>
</div>

<div class="container">

<div class="section-title">Enter Game ID</div>

<div class="input-box">
<input id="userid" placeholder="User ID">
</div>

<div class="input-box">
<input id="zoneid" placeholder="Zone ID">
</div>

<div class="section-title">Select Package</div>

<div class="packages">

<div class="package" onclick="selectPackage('Weekly Pass',152)">
Weekly Pass<br>
<span class="price">₹152</span>
</div>

<div class="package" onclick="selectPackage('55 Diamonds',80)">
55 Diamonds<br>
<span class="price">₹80</span>
</div>

<div class="package" onclick="selectPackage('110 Diamonds',156)">
110 Diamonds<br>
<span class="price">₹156</span>
</div>

<div class="package" onclick="selectPackage('172 Diamonds',244)">
172 Diamonds<br>
<span class="price">₹244</span>
</div>

<div class="package" onclick="selectPackage('257 Diamonds',353)">
257 Diamonds<br>
<span class="price">₹353</span>
</div>

<div class="package" onclick="selectPackage('343 Diamonds',475)">
343 Diamonds<br>
<span class="price">₹475</span>
</div>

</div>

<button onclick="orderNow()">BUY NOW</button>

</div>

<footer>
TAMNALAI STORE © 2026
</footer>

<script>

let product=""
let price=""

function selectPackage(p,pr){

product=p
price=pr

alert("Selected: "+p)

}

function orderNow(){

let uid=document.getElementById("userid").value
let zid=document.getElementById("zoneid").value

if(uid=="" || zid==""){
alert("Enter User ID & Zone ID")
return
}

if(product==""){
alert("Select Package")
return
}

let msg=
"MLBB TOPUP ORDER%0A%0A"+
"Store: TAMNALAI STORE%0A"+
"User ID: "+uid+"%0A"+
"Zone ID: "+zid+"%0A"+
"Package: "+product+"%0A"+
"Price: ₹"+price

window.open("https://wa.me/919862277104?text="+msg)

}

</script>

</body>
</html>
